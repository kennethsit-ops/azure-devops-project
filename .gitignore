# Terraform working directory
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Ignore Terraform variable files by default
*.tfvars

# Commit approved non-sensitive environment configuration
!terraform/dev.tfvars
!terraform/test.tfvars
!terraform/prod.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc